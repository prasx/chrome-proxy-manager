{
  "manifest_version": 3,
  "name": "Proxy Manager",
  "version": "0.4.1",
  "description": "Управление маршрутизацией трафика через локальный proxy",
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webNavigation",
    "contextMenus",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  }
}
